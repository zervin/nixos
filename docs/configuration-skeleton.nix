# =============================================================================
# EXAMPLE DEVSHELL: Flutter Project (~/projects/my-flutter-app/flake.nix)
# =============================================================================
# This shows how to create a project-specific dev environment that does NOT
# pollute the global system. cd into the project, run `nix develop`, and
# get Flutter + Dart + Android SDK. Exit the shell, they are gone.
#
# With direnv enabled (see Home Manager config above), just add a file
# `.envrc` containing `use flake` in the project root, and the devShell
# activates automatically on cd.
/*
{
  description = "Flutter development environment";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-24.11";
    flake-utils.url = "github:numtide/flake-utils";
  };

  outputs = { self, nixpkgs, flake-utils }:
    flake-utils.lib.eachDefaultSystem (system:
      let
        pkgs = import nixpkgs {
          inherit system;
          config.allowUnfree = true;
          config.android_sdk.accept_license = true;
        };

        # Android SDK configuration
        androidComposition = pkgs.androidenv.composeAndroidPackages {
          platformVersions = [ "34" "33" ];
          buildToolsVersions = [ "34.0.0" ];
          includeEmulator = false;
          includeSystemImages = false;
          includeSources = false;
        };
      in {
        devShells.default = pkgs.mkShell {
          packages = with pkgs; [
            flutter
            dart
            jdk21
            androidComposition.androidsdk
          ];

          ANDROID_HOME = "${androidComposition.androidsdk}/libexec/android-sdk";
          JAVA_HOME = "${pkgs.jdk21}";

          shellHook = ''
            echo "Flutter dev environment loaded"
            echo "  Flutter: $(flutter --version | head -1)"
            echo "  Dart:    $(dart --version 2>&1)"
            echo "  Java:    $(java --version 2>&1 | head -1)"
          '';
        };
      }
    );
}
*/

